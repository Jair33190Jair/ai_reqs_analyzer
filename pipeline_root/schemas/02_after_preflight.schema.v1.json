{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["source_meta", "checks", "score", "pass"],
  "properties": {
    "source_meta": {
      "type": "object",
      "required": ["filename"],
      "properties": {
        "filename": { "type": "string" },
        "doc_version": {
          "type": ["string", "null"]
        },
        "doc_last_modified": {
          "type": ["string", "null"]
        }
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "has_item_ids",
        "item_id_count",
        "unique_item_id_count",
        "duplicate_item_ids",
        "sections_count",
        "unique_section_count",
        "duplicate_sections",
        "unparseable_line_count",
        "total_line_count"
      ],
      "properties": {
        "has_item_ids":         { "type": "boolean" },
        "item_id_count":        { "type": "integer", "minimum": 0 },
        "unique_item_id_count": { "type": "integer", "minimum": 0 },
        "duplicate_item_ids":   { "type": "array", "items": { "type": "string" } },
        "sections_count":       { "type": "integer", "minimum": 0 },
        "unique_section_count": { "type": "integer", "minimum": 0 },
        "duplicate_sections":   { "type": "array", "items": { "type": "string" } },
        "unparseable_line_count": { "type": "integer", "minimum": 0 },
        "total_line_count":       { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "score": { "type": "number", "minimum": 0, "maximum": 1 },
    "pass":  { "type": "boolean" }
  },
  "additionalProperties": false
}
