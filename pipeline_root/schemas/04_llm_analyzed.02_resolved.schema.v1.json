{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "description": "Stage 04 resolved artifact — LLM raw findings enriched by post-processing: stable IDs assigned, dispositions initialized, aggregate stats computed.",
  "type": "object",
  "required": ["source_ref", "analysis_meta", "findings", "item_review", "stats"],
  "additionalProperties": false,

  "definitions": {

    "affected_item": {
      "type": "object",
      "required": ["gen_uid", "role"],
      "additionalProperties": false,
      "properties": {
        "gen_uid": {
          "type": "string",
          "pattern": "^GU-[0-9A-F]{6}$",
          "description": "Content fingerprint from stage 03. Primary join key — position-independent and change-sensitive."
        },
        "spec_item_id": {
          "type": ["string", "null"],
          "description": "Human-readable ID (e.g. SWRS-1234) if the requirement carries one. Null for raw specs."
        },
        "gen_hierarchy_number": {
          "type": ["string", "null"],
          "description": "Positional reference (e.g. 'G3.1-002') for human navigation. Informational only — do not use as a join key."
        },
        "role": {
          "type": "string",
          "enum": ["primary", "conflicting", "related"]
        }
      }
    },

    "finding": {
      "type": "object",
      "required": ["gen_find_id", "pass", "type", "category", "severity", "affected_items", "description", "confidence"],
      "additionalProperties": false,
      "properties": {
        "gen_find_id": {
          "type": "string",
          "pattern": "^GF-[0-9A-F]{6}$",
          "description": "Finding ID assigned by post-processing. sha256(source_ref + spec_item_id_or_gen_hierarchy_number + category + pass)[:6 hex uppercase]. Uses spec_item_id when present, gen_hierarchy_number as fallback for raw specs."
        },
        "pass": {
          "type": "string",
          "enum": ["INDIVIDUAL_QUALITY"],
          "description": "Which analysis pass generated this finding. Extend enum when new passes are introduced."
        },
        "type": {
          "type": "string",
          "enum": ["FINDING", "QUESTION", "OBSERVATION"]
        },
        "category": {
          "type": "string",
          "enum": [
            "AMBIGUITY",
            "ATOMICITY",
            "COMPLETENESS",
            "CONSISTENCY",
            "FEASIBILITY",
            "OVERCONSTRAINT",
            "REDUNDANCY",
            "SAFETY",
            "SECURITY",
            "TERMINOLOGY",
            "TESTABILITY",
            "TIMING",
            "TRACEABILITY",
            "OTHER"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["CRITICAL", "MAJOR", "MINOR", "INFO"]
        },
        "affected_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/affected_item" }
        },
        "description": {
          "type": "string"
        },
        "recommendation": {
          "type": ["string", "null"]
        },
        "reference": {
          "type": ["string", "null"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },

    "severity_counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "CRITICAL": { "type": "integer", "minimum": 0 },
        "MAJOR":    { "type": "integer", "minimum": 0 },
        "MINOR":    { "type": "integer", "minimum": 0 },
        "INFO":     { "type": "integer", "minimum": 0 }
      }
    },

    "type_counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "FINDING":     { "type": "integer", "minimum": 0 },
        "QUESTION":    { "type": "integer", "minimum": 0 },
        "OBSERVATION": { "type": "integer", "minimum": 0 }
      }
    },

    "item_review_entry": {
      "description": "Per-item review status computed by post-processing from findings + reviewed_items.",
      "type": "object",
      "required": ["gen_uid", "spec_item_id", "status", "finding_ids"],
      "additionalProperties": false,
      "properties": {
        "gen_uid": {
          "type": "string",
          "pattern": "^GU-[0-9A-F]{6}$"
        },
        "spec_item_id": {
          "type": ["string", "null"]
        },
        "status": {
          "type": "string",
          "enum": ["FLAGGED", "PASSED", "SKIPPED"],
          "description": "FLAGGED: reviewed, has findings. PASSED: reviewed, no findings. SKIPPED: not in reviewed_items."
        },
        "finding_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^GF-[0-9A-F]{6}$"
          }
        }
      }
    }

  },

  "properties": {
    "source_ref": {
      "type": "string",
      "description": "Filename of the stage-03 resolved artifact this analysis was run against."
    },

    "analysis_meta": {
      "type": "object",
      "required": ["pass", "model", "prompt_version", "timestamp"],
      "additionalProperties": false,
      "properties": {
        "pass": {
          "type": "string",
          "enum": ["INDIVIDUAL_QUALITY"]
        },
        "model": {
          "type": "string",
          "description": "Model ID used (e.g. 'claude-sonnet-4-6')."
        },
        "prompt_version": {
          "type": "string",
          "description": "Version tag of the prompt template. Allows correlating findings to prompt changes."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "doc_version": {
          "type": ["string", "null"],
          "description": "Document revision/version string extracted from the source, if available."
        }
      }
    },

    "findings": {
      "type": "array",
      "description": "All findings in document order (sorted by primary affected_item gen_hierarchy_number).",
      "items": { "$ref": "#/definitions/finding" }
    },

    "item_review": {
      "type": "array",
      "description": "Per-item review status. One entry per spec_item from stage 03, computed by post-processing.",
      "items": { "$ref": "#/definitions/item_review_entry" }
    },

    "stats": {
      "type": "object",
      "required": ["total_items", "reviewed", "skipped", "flagged", "passed", "total_findings", "by_severity", "by_type"],
      "additionalProperties": false,
      "description": "Aggregate counts. Computed by post-processing, not the LLM.",
      "properties": {
        "total_items":    { "type": "integer", "minimum": 0, "description": "Total spec_items in stage 03 input." },
        "reviewed":       { "type": "integer", "minimum": 0, "description": "Items in reviewed_items list." },
        "skipped":        { "type": "integer", "minimum": 0, "description": "total_items - reviewed." },
        "flagged":        { "type": "integer", "minimum": 0, "description": "Reviewed items with at least one finding." },
        "passed":         { "type": "integer", "minimum": 0, "description": "Reviewed items with zero findings." },
        "total_findings": { "type": "integer", "minimum": 0, "description": "Total number of findings." },
        "by_severity":    { "$ref": "#/definitions/severity_counts" },
        "by_type":        { "$ref": "#/definitions/type_counts" }
      }
    }
  }
}
