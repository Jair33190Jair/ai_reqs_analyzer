{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "type": "object",
  "required": ["source_meta", "normalization", "pages"],
  "properties": {
    "source_meta": {
      "type": "object",
      "required": ["filename"],
      "properties": {
        "filename": {
          "type": "string",
          "description": "Original PDF filename from S0 source_meta."
        },
        "doc_version": {
          "type": ["string", "null"],
          "description": "Document version/revision extracted by LLM, or null if not found."
        },
        "doc_last_modified": {
          "type": ["string", "null"],
          "description": "Document last-modified date extracted by LLM (YYYY-MM-DD when possible), or null if not found."
        }
      }
    },
    "normalization": {
      "type": "object",
      "required": [
        "dehyphenation",
        "ligature_map",
        "line_joining",
        "header_footer_strip",
        "item_id_pattern",
        "heading_pattern"
      ],
      "properties": {
        "dehyphenation":      { "type": "boolean" },
        "ligature_map":       { "type": "boolean" },
        "line_joining":       { "type": "string", "enum": ["none"] },
        "header_footer_strip":{ "type": "string", "enum": ["heuristic", "none"] },
        "item_id_pattern": {
          "type": ["string", "null"],
          "description": "Python regex that matches a standalone requirement ID line (e.g. REQ-001), or null for raw specs without formal IDs."
        },
        "heading_pattern": {
          "type": ["string", "null"],
          "description": "Python regex that matches a section heading line, or null if not detected."
        }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page", "text"],
        "properties": {
          "page": { "type": "integer" },
          "text": { "type": "string" }
        }
      }
    }
  }
}
