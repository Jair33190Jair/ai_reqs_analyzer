      "hierarchical_number": null,
      "item_type": "requirement",
      "classification": "security",
      "source": "inline",
      "loc": {
        "page": 4,
        "line_start": 20,
        "line_end": 21
      },
      "content": "SYS-SEC-001\nAll external communications shall use TLS 1.2 or higher.",
