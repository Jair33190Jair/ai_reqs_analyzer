    },
    {
      "item_id": "SYS-SEC-003",
      "hierarchical_number": null,
      "item_type": "requirement",
      "classification": "security",
      "source": "inline",
      "loc": {
        "page": 5,
        "line_start": 3,
        "line_end": 4
      },
      "content": "SYS-SEC-003\nThe system shall implement secure boot with firmware signature validation.",
      "internal_id": "G6-003"
    },
