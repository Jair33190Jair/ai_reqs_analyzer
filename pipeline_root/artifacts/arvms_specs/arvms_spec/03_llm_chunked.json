  "spec_items": [
    {
      "item_id": "SYS-FUNC-001",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS007",
      "loc": {
        "page": 2,
        "line_start": 3,
        "line_end": 4
      },
      "content": "SYS-FUNC-001\nThe system shall autonomously generate a 2D indoor map using SLAM."
    },
    {
      "item_id": "SYS-FUNC-002",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS007",
      "loc": {
        "page": 2,
        "line_start": 5,
        "line_end": 6
      },
      "content": "SYS-FUNC-002\nThe system shall localize itself with ±5 cm accuracy."
    },
    {
      "item_id": "SYS-FUNC-003",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS007",
      "loc": {
        "page": 2,
        "line_start": 7,
        "line_end": 8
      },
      "content": "SYS-FUNC-003\nThe system shall avoid static and dynamic obstacles in real-time."
    },
    {
      "item_id": "SYS-FUNC-004",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS007",
      "loc": {
        "page": 2,
        "line_start": 9,
        "line_end": 10
      },
      "content": "SYS-FUNC-004\nThe system shall detect cliffs or stairs and prevent falling."
    },
    {
      "item_id": "SYS-FUNC-005",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS007",
      "loc": {
        "page": 2,
        "line_start": 11,
        "line_end": 12
      },
      "content": "SYS-FUNC-005\nThe system shall support multi-room mapping and segmentation."
    },
    {
      "item_id": "SYS-FUNC-010",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS008",
      "loc": {
        "page": 2,
        "line_start": 14,
        "line_end": 15
      },
      "content": "SYS-FUNC-010\nThe system shall generate suction power >= 5000 Pa."
    },
    {
      "item_id": "SYS-FUNC-011",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS008",
      "loc": {
        "page": 2,
        "line_start": 16,
        "line_end": 17
      },
      "content": "SYS-FUNC-011\nThe system shall automatically adjust suction based on detected floor type."
    },
    {
      "item_id": "SYS-FUNC-012",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS008",
      "loc": {
        "page": 2,
        "line_start": 18,
        "line_end": 19
      },
      "content": "SYS-FUNC-012\nThe system shall detect carpet surfaces."
    },
    {
      "item_id": "SYS-FUNC-020",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS009",
      "loc": {
        "page": 2,
        "line_start": 21,
        "line_end": 22
      },
      "content": "SYS-FUNC-020\nThe system shall provide electronically controlled water dispensing."
    },
    {
      "item_id": "SYS-FUNC-021",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS009",
      "loc": {
        "page": 2,
        "line_start": 23,
        "line_end": 24
      },
      "content": "SYS-FUNC-021\nThe system shall support adjustable water flow levels (Low/Medium/High)."
    },
    {
      "item_id": "SYS-FUNC-022",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS009",
      "loc": {
        "page": 3,
        "line_start": 1,
        "line_end": 2
      },
      "content": "SYS-FUNC-022\nThe system shall lift the mop automatically when carpet is detected."
    },
    {
      "item_id": "SYS-FUNC-023",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS009",
      "loc": {
        "page": 3,
        "line_start": 3,
        "line_end": 4
      },
      "content": "SYS-FUNC-023\nThe system shall detect empty water tank conditions and notify the user."
    },
    {
      "item_id": "SYS-FUNC-030",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS010",
      "loc": {
        "page": 3,
        "line_start": 6,
        "line_end": 8
      },
      "content": "SYS-FUNC-030\nThe system shall automatically return to the charging dock when battery <\n20%."
    },
    {
      "item_id": "SYS-FUNC-031",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS010",
      "loc": {
        "page": 3,
        "line_start": 9,
        "line_end": 10
      },
      "content": "SYS-FUNC-031\nThe system shall resume cleaning after recharge."
    },
    {
      "item_id": "SYS-FUNC-032",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS010",
      "loc": {
        "page": 3,
        "line_start": 11,
        "line_end": 12
      },
      "content": "SYS-FUNC-032\nThe system shall support automatic charging."
    },
    {
      "item_id": "SYS-FUNC-040",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS011",
      "loc": {
        "page": 3,
        "line_start": 14,
        "line_end": 15
      },
      "content": "SYS-FUNC-040\nThe system shall support cleaning scheduling."
    },
    {
      "item_id": "SYS-FUNC-041",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS011",
      "loc": {
        "page": 3,
        "line_start": 16,
        "line_end": 17
      },
      "content": "SYS-FUNC-041\nThe system shall allow room-specific cleaning selection."
    },
    {
      "item_id": "SYS-FUNC-042",
      "item_type": "requirement",
      "classification": "functional",
      "source": "inline",
      "parent_gen_section_number": "GS011",
      "loc": {
        "page": 3,
        "line_start": 18,
        "line_end": 19
      },
      "content": "SYS-FUNC-042\nThe system shall provide cleaning reports (area, duration, battery usage)."
    },
    {
      "item_id": "SYS-SAFE-001",
      "item_type": "requirement",
      "classification": "safety",
      "source": "inline",
      "parent_gen_section_number": "GS013",
      "loc": {
        "page": 3,
        "line_start": 22,
        "line_end": 23
      },
      "content": "SYS-SAFE-001\nThe system shall stop all drive motors within 100 ms if lifted."
    },
    {
      "item_id": "SYS-SAFE-002",
      "item_type": "requirement",
      "classification": "safety",
      "source": "inline",
      "parent_gen_section_number": "GS013",
      "loc": {
        "page": 4,
        "line_start": 1,
        "line_end": 2
      },
      "content": "SYS-SAFE-002\nThe system shall limit brush torque to prevent injury."
    },
    {
      "item_id": "SYS-SAFE-003",
      "item_type": "requirement",
      "classification": "safety",
      "source": "inline",
      "parent_gen_section_number": "GS013",
      "loc": {
        "page": 4,
        "line_start": 3,
        "line_end": 4
      },
      "content": "SYS-SAFE-003\nThe system shall prevent operation if the dustbin is removed."
    },
    {
      "item_id": "SYS-SAFE-010",
      "item_type": "requirement",
      "classification": "safety",
      "source": "inline",
      "parent_gen_section_number": "GS014",
      "loc": {
        "page": 4,
        "line_start": 6,
        "line_end": 7
      },
      "content": "SYS-SAFE-010\nThe system shall prevent battery overcharge and deep discharge."
    },
    {
      "item_id": "SYS-SAFE-011",
      "item_type": "requirement",
      "classification": "safety",
      "source": "inline",
      "parent_gen_section_number": "GS014",
      "loc": {
        "page": 4,
        "line_start": 8,
        "line_end": 9
      },
      "content": "SYS-SAFE-011\nThe system shall monitor motor temperature and prevent overheating."
    },
    {
      "item_id": "SYS-PERF-001",
      "item_type": "requirement",
      "classification": "performance",
      "source": "inline",
      "parent_gen_section_number": "GS015",
      "loc": {
        "page": 4,
        "line_start": 11,
        "line_end": 12
      },
      "content": "SYS-PERF-001\nCleaning coverage efficiency shall be >= 95%."
    },
    {
      "item_id": "SYS-PERF-002",
      "item_type": "requirement",
      "classification": "performance",
      "source": "inline",
      "parent_gen_section_number": "GS015",
      "loc": {
        "page": 4,
        "line_start": 13,
        "line_end": 14
      },
      "content": "SYS-PERF-002\nMaximum noise level shall be <= 65 dB."
    },
    {
      "item_id": "SYS-PERF-003",
      "item_type": "requirement",
      "classification": "performance",
      "source": "inline",
      "parent_gen_section_number": "GS015",
      "loc": {
        "page": 4,
        "line_start": 15,
        "line_end": 16
      },
      "content": "SYS-PERF-003\nOperating time shall be >= 120 minutes."
    },
    {
      "item_id": "SYS-PERF-004",
      "item_type": "requirement",
      "classification": "performance",
      "source": "inline",
      "parent_gen_section_number": "GS015",
      "loc": {
        "page": 4,
        "line_start": 17,
        "line_end": 18
      },
      "content": "SYS-PERF-004\nCharging time shall be <= 4 hours."
    },
    {
      "item_id": "SYS-SEC-001",
      "item_type": "requirement",
      "classification": "security",
      "source": "inline",
      "parent_gen_section_number": "GS016",
      "loc": {
        "page": 4,
        "line_start": 20,
        "line_end": 21
      },
      "content": "SYS-SEC-001\nAll external communications shall use TLS 1.2 or higher."
    },
    {
      "item_id": "SYS-SEC-002",
      "item_type": "requirement",
      "classification": "security",
      "source": "inline",
      "parent_gen_section_number": "GS016",
      "loc": {
        "page": 5,
        "line_start": 1,
        "line_end": 2
      },
      "content": "SYS-SEC-002\nThe system shall support secure OTA firmware updates."
    },
    {
      "item_id": "SYS-SEC-003",
      "item_type": "requirement",
      "classification": "security",
      "source": "inline",
      "parent_gen_section_number": "GS016",
      "loc": {
        "page": 5,
        "line_start": 3,
        "line_end": 4
      },
      "content": "SYS-SEC-003\nThe system shall implement secure boot with firmware signature validation."
    },
    {
      "item_id": "SYS-HW-001",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS018",
      "loc": {
        "page": 5,
        "line_start": 7,
        "line_end": 8
      },
      "content": "SYS-HW-001\nThe system shall include a LIDAR or vision-based navigation sensor."
    },
    {
      "item_id": "SYS-HW-002",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS018",
      "loc": {
        "page": 5,
        "line_start": 9,
        "line_end": 10
      },
      "content": "SYS-HW-002\nThe system shall include cliff detection sensors."
    },
    {
      "item_id": "SYS-HW-003",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS018",
      "loc": {
        "page": 5,
        "line_start": 11,
        "line_end": 12
      },
      "content": "SYS-HW-003\nThe system shall include wheel encoders."
    },
    {
      "item_id": "SYS-HW-004",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS018",
      "loc": {
        "page": 5,
        "line_start": 13,
        "line_end": 14
      },
      "content": "SYS-HW-004\nThe system shall include an IMU."
    },
    {
      "item_id": "SYS-HW-005",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS018",
      "loc": {
        "page": 5,
        "line_start": 15,
        "line_end": 16
      },
      "content": "SYS-HW-005\nThe system shall include a water level sensor."
    },
    {
      "item_id": "SYS-HW-010",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS019",
      "loc": {
        "page": 5,
        "line_start": 18,
        "line_end": 19
      },
      "content": "SYS-HW-010\nThe system shall include two independent drive motors."
    },
    {
      "item_id": "SYS-HW-011",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS019",
      "loc": {
        "page": 5,
        "line_start": 20,
        "line_end": 21
      },
      "content": "SYS-HW-011\nThe system shall include a vacuum motor."
    },
    {
      "item_id": "SYS-HW-012",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS019",
      "loc": {
        "page": 5,
        "line_start": 22,
        "line_end": 23
      },
      "content": "SYS-HW-012\nThe system shall include a water pump."
    },
    {
      "item_id": "SYS-HW-013",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS019",
      "loc": {
        "page": 6,
        "line_start": 1,
        "line_end": 2
      },
      "content": "SYS-HW-013\nThe system shall include a mop lift actuator."
    },
    {
      "item_id": "SYS-SW-001",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS020",
      "loc": {
        "page": 6,
        "line_start": 4,
        "line_end": 8
      },
      "content": "SYS-SW-001\nThe system shall implement a layered software architecture:\n• Application Layer\n• Middleware Layer\n• Hardware Abstraction Layer (HAL)"
    },
    {
      "item_id": "SYS-SW-002",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS020",
      "loc": {
        "page": 6,
        "line_start": 9,
        "line_end": 10
      },
      "content": "SYS-SW-002\nThe system shall support modular firmware updates."
    },
    {
      "item_id": "SYS-SW-003",
      "item_type": "requirement",
      "classification": "other",
      "source": "inline",
      "parent_gen_section_number": "GS020",
      "loc": {
        "page": 6,
        "line_start": 11,
        "line_end": 12
      },
      "content": "SYS-SW-003\nThe system shall log diagnostic events with timestamps."
    }
  ]
}